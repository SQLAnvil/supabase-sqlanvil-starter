  VALUES
    (1, 101, DATE '2024-01-01', 1000),
    (2, 102, DATE '2024-01-01', 2500),
    (3, 101, DATE '2024-01-02', 1500)
) AS t(order_id, customer_id, order_date, amount_cents)
